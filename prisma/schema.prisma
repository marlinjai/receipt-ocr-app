generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DtTable {
  id          String     @id @default(uuid())
  workspaceId String     @map("workspace_id")
  name        String
  description String?
  icon        String?
  migrated    Boolean    @default(false)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  columns     DtColumn[]
  views       DtView[]

  @@map("dt_tables")
}

model DtColumn {
  id        String   @id @default(uuid())
  tableId   String   @map("table_id")
  name      String
  type      String
  position  Int
  width     Int      @default(200)
  isPrimary Boolean  @default(false) @map("is_primary")
  config    Json?
  alignment String?
  createdAt DateTime @default(now()) @map("created_at")
  table     DtTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("dt_columns")
}

model SelectOption {
  id       String  @id @default(uuid())
  columnId String  @map("column_id")
  name     String
  color    String?
  position Int

  @@map("select_options")
}

model DtRowSelectValue {
  id       String @id @default(uuid())
  rowId    String @map("row_id")
  columnId String @map("column_id")
  optionId String @map("option_id")

  @@unique([rowId, columnId, optionId])
  @@map("dt_row_select_values")
}

model DtRelation {
  id             String   @id @default(uuid())
  sourceRowId    String   @map("source_row_id")
  sourceColumnId String   @map("source_column_id")
  targetRowId    String   @map("target_row_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([sourceRowId, sourceColumnId, targetRowId])
  @@map("dt_relations")
}

model DtFile {
  id           String  @id @default(uuid())
  rowId        String  @map("row_id")
  columnId     String  @map("column_id")
  fileId       String  @map("file_id")
  fileUrl      String  @map("file_url")
  originalName String  @map("original_name")
  mimeType     String  @map("mime_type")
  sizeBytes    Int?    @map("size_bytes")
  position     Int     @default(0)
  metadata     Json?

  @@map("dt_files")
}

model DtView {
  id        String   @id @default(uuid())
  tableId   String   @map("table_id")
  name      String
  type      String   @default("table")
  isDefault Boolean  @default(false) @map("is_default")
  position  Int      @default(0)
  config    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  table     DtTable  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("dt_views")
}

model DtRow {
  id        String  @id @default(uuid())
  tableId   String  @map("table_id")
  cells     Json?
  computed  Json?
  title     String? @map("_title")
  archived  Int     @default(0) @map("_archived")
  createdAt String  @map("_created_at")
  updatedAt String  @map("_updated_at")

  @@map("dt_rows")
}

// Per-user Google connection for the Sheets importer. One row per auth-brain
// user; the refresh token is stored AES-256-GCM encrypted (never in plaintext).
// The token authorizes reading the user's own Sheets (spreadsheets.readonly);
// it is unrelated to auth-brain, which governs who may use Receipts at all.
model GoogleSheetsCredential {
  id                    String   @id @default(uuid())
  authUserId            String   @unique @map("auth_user_id")
  googleEmail           String?  @map("google_email")
  refreshTokenEncrypted String   @map("refresh_token_encrypted")
  scopes                String
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("google_sheets_credentials")
}

// A saved Sheets import for one workspace (company book): which spreadsheet/tab,
// how its columns map onto the Receipts fields, and which fields form the dedup
// identity. Scoped by the auth-brain workspace UUID (the same value that
// partitions dt_tables.workspace_id), so each company's import is isolated.
model SheetImportConfig {
  id              String    @id @default(uuid())
  authWorkspaceId String    @map("auth_workspace_id")
  spreadsheetId   String    @map("spreadsheet_id")
  sheetName       String    @map("sheet_name")
  headerRow       Int       @default(1) @map("header_row")
  columnMapping   Json      @map("column_mapping")
  dedupKeyFields  Json      @map("dedup_key_fields")
  createdByUserId String    @map("created_by_user_id")
  lastRunAt       DateTime? @map("last_run_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  rows            SheetImportRow[]

  @@unique([authWorkspaceId, spreadsheetId, sheetName])
  @@map("sheet_import_configs")
}

// Dedup ledger mapping an imported sheet row (by stable key) to the dt_rows row
// it produced, so a re-run upserts instead of duplicating. Kept separate from
// dt_rows to leave the generic data-table schema untouched.
model SheetImportRow {
  id        String            @id @default(uuid())
  configId  String            @map("config_id")
  dedupKey  String            @map("dedup_key")
  dtRowId   String            @map("dt_row_id")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  config    SheetImportConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, dedupKey])
  @@map("sheet_import_rows")
}

// Workspace-editable per-vendor attribution %, the configurable replacement for
// the hardcoded VENDOR_BUSINESS_SHARE_DEFAULTS. `share` is 0-100. The reserved
// vendor `*` row carries the workspace default for unlisted vendors (else 100).
// "Apply to ledger" writes these onto each matching row's Business Share %.
model WorkspaceVendorAttribution {
  id              String   @id @default(uuid())
  authWorkspaceId String   @map("auth_workspace_id")
  vendor          String
  share           Int
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([authWorkspaceId, vendor])
  @@map("workspace_vendor_attribution")
}

// The overview's editable notes block (reconciliation / attribution commentary),
// one per workspace.
model WorkspaceNotes {
  id              String   @id @default(uuid())
  authWorkspaceId String   @unique @map("auth_workspace_id")
  body            String   @default("")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("workspace_notes")
}

// Historical ECB reference-rate cache (via api.frankfurter.dev), keyed by invoice
// date so the same currency/date pair is never fetched twice.
model FxRate {
  id        String   @id @default(uuid())
  date      String
  currency  String
  rate      Float
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@unique([date, currency])
  @@map("fx_rates")
}
