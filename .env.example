# ============================================================
# Receipt OCR App — Environment Variables
# Mount via 1Password Environments as .env.local (dev) or .env (prod)
# ============================================================

# Database (Postgres)
DATABASE_URL=postgres://receipts:password@postgres:5432/receipts

# Storage Brain (file uploads to R2)
NEXT_PUBLIC_STORAGE_BRAIN_URL=https://storage-brain-api.marlin-pohl.workers.dev
STORAGE_BRAIN_API_KEY=

# Google Cloud Vision (OCR text extraction)
GOOGLE_CLOUD_VISION_API_KEY=

# OpenRouter (AI classification — category, Konto, Zuordnung)
OPENROUTER_API_KEY=
