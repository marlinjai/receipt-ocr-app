# ============================================================
# Receipt OCR App — Environment Variables
# Mount via 1Password Environments as .env.local (dev) or .env (prod)
# ============================================================

# Database (Postgres)
DATABASE_URL=postgres://receipts:password@postgres:5432/receipts

# Storage Brain (file uploads to R2)
NEXT_PUBLIC_STORAGE_BRAIN_URL=https://storage-brain-api.marlin-pohl.workers.dev
STORAGE_BRAIN_API_KEY=

# Google Cloud Vision (OCR text extraction)
GOOGLE_CLOUD_VISION_API_KEY=

# OpenRouter (AI classification — category, Konto, Zuordnung)
OPENROUTER_API_KEY=

# Google Sheets importer (per-user OAuth to read the user's own sheets).
# Separate OAuth client from auth-brain login; scope: spreadsheets.readonly.
# Redirect URI: https://receipts.lumitra.co/api/google/oauth/callback (+ localhost for dev).
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
# 32-byte key sealing the stored Google refresh token (AES-256-GCM).
# Generate with: openssl rand -hex 32
SHEETS_TOKEN_ENC_KEY=
