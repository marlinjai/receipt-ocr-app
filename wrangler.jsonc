{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "receipt-ocr-app",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "receipts.lumitra.co", "custom_domain": true }
  ],
  "vars": {
    "NEXT_PUBLIC_STORAGE_BRAIN_URL": "https://storage-brain-api.marlin-pohl.workers.dev",
    "NEXT_PUBLIC_STORAGE_BRAIN_API_KEY": "sk_live_xdGLKNVSOCvHY3G2Y-4TnSoIvtbVu7y8"
  },
  // TODO: run `wrangler d1 create receipt-ocr-db` to get the real database_id and replace the placeholder below
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "receipt-ocr-db",
      "database_id": "TODO-run-wrangler-d1-create-receipt-ocr-db"
    }
  ]
}
